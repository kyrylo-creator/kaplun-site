---
lang: uk
layout: base.njk
title: Блог
description: "Думки про тривогу, стосунки, вигорання, адаптацію за кордоном і поєднання роботи з психікою та тілом — Олександр Каплун."
permalink: /uk/blog/
---
{%- set L = lang or "uk" -%}
{%- set t = i18n[L] -%}
<section class="blog-hero">
  <div class="container">
    <p class="eyebrow">{{ t.blog.eyebrow }}</p>
    <h1 class="blog-hero__title">{{ t.blog.heading }}</h1>
    <p class="blog-hero__lead">{{ t.blog.lead }}</p>
  </div>
</section>

<section class="section" style="padding-top:24px">
  <div class="container">
    {% if collections.posts_uk.length %}
    <div class="posts">
      {% for post in collections.posts_uk %}
      <a class="post-card reveal" href="{{ post.url }}">
        <div class="post-card__body">
          <span class="post-card__meta">{{ post.data.category }}</span>
          <h2>{{ post.data.title }}</h2>
          {% if post.data.excerpt %}<p>{{ post.data.excerpt }}</p>{% endif %}
          <span class="post-card__link">{{ t.blog.readMore }}</span>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="placeholder-box">{{ t.blog.empty }}</div>
    {% endif %}
  </div>
</section>
