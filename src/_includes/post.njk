---
layout: base.njk
ogType: article
---
{%- set L = lang or "uk" -%}
{%- set t = i18n[L] -%}
<article class="article">
  <div class="container container--narrow">
    <a href="{{ t.blogUrl }}" class="article__back">{{ t.post.back }}</a>

    <p class="article__meta">
      {{ category }}{% if date %} · {{ date | dateUk }}{% endif %}
    </p>
    <h1 class="article__title">{{ title }}</h1>

    {% if excerpt %}<p class="article__lead">{{ excerpt }}</p>{% endif %}

    {{ content | safe }}

    <div class="article__cta">
      <p>{{ t.post.ctaQuestion }}</p>
      <a href="{{ t.contactsUrl }}" class="btn btn--primary">{{ t.post.ctaButton }}</a>
    </div>
  </div>
</article>
