{%- set L = lang or "uk" -%}
{%- set t = i18n[L] -%}
<!DOCTYPE html>
<html lang="{{ t.htmlLang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{{ title }} — {{ t.post.siteSuffix }}</title>
  <meta name="description" content="{{ description or excerpt }}" />
  <link rel="canonical" href="https://sashkopsy.com{{ page.url }}" />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <meta name="theme-color" content="#3d5a40" />

  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:locale" content="{{ t.ogLocale }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description or excerpt }}" />
  <meta property="og:url" content="https://sashkopsy.com{{ page.url }}" />
  <meta property="og:image" content="https://sashkopsy.com/assets/photo.JPG" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ description or excerpt }}" />
  <meta name="twitter:image" content="https://sashkopsy.com/assets/photo.JPG" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />

  {% if ogType == "article" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ description or excerpt }}",
    "image": "https://sashkopsy.com/assets/photo.JPG",
    "datePublished": "{{ date | dateISO }}",
    "dateModified": "{{ date | dateISO }}",
    "inLanguage": "{{ t.htmlLang }}",
    "author": {
      "@type": "Person",
      "name": "{{ t.footer.brand }}",
      "url": "https://sashkopsy.com{{ t.homeUrl }}"
    },
    "publisher": {
      "@type": "Person",
      "name": "{{ t.footer.brand }}",
      "url": "https://sashkopsy.com{{ t.homeUrl }}"
    },
    "mainEntityOfPage": "https://sashkopsy.com{{ page.url }}"
  }
  </script>
  {% endif %}
</head>
<body>

  <header class="nav">
    <div class="container nav__inner">
      <a href="{{ t.homeUrl }}#top" class="brand">
        <svg class="brand__mark" viewBox="0 0 100 100" aria-hidden="true" focusable="false"><path d="M 81 28 A 38 38 0 1 1 60 13" fill="none" stroke="currentColor" stroke-width="7" stroke-linecap="round"/></svg>
        <span>{{ t.footer.brand }}</span>
      </a>
      <nav class="nav__links" id="navLinks">
        <a href="{{ t.homeUrl }}#about">{{ t.nav.about }}</a>
        <a href="{{ t.homeUrl }}#services">{{ t.nav.services }}</a>
        <a href="{{ t.homeUrl }}#approach">{{ t.nav.approach }}</a>
        <a href="{{ t.blogUrl }}">{{ t.nav.blog }}</a>
        <a href="{{ t.contactsUrl }}" class="nav__cta">{{ t.nav.book }}</a>
        <span class="lang-switch">
          <a {% if L == "uk" %}class="lang-switch__cur"{% endif %} href="/uk/">UK</a>
          <a {% if L == "en" %}class="lang-switch__cur"{% endif %} href="/">EN</a>
          <a {% if L == "ru" %}class="lang-switch__cur"{% endif %} href="/ru/">RU</a>
        </span>
      </nav>
      <button class="nav__toggle" id="navToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  {{ content | safe }}

  <footer class="footer">
    <div class="container footer__inner">
      <div>
        <div class="footer__name">{{ t.footer.brand }}</div>
        <small>{{ t.footer.role }}</small>
      </div>
      <div class="footer__links">
        <a href="{{ t.blogUrl }}">{{ t.nav.blog }}</a>
        <a href="{{ t.contactsUrl }}">{{ t.nav.book }}</a>
      </div>
    </div>
    <div class="container" style="margin-top:24px;color:#d8e0cf;font-size:.82rem">
      © <span id="year"></span> {{ t.footer.brand }}. {{ t.footer.rights }}
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
