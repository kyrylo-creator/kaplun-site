<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{{ title }} — Олександр Каплун</title>
  <meta name="description" content="{{ description or excerpt }}" />
  <link rel="canonical" href="https://sashkopsy.com{{ page.url }}" />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <meta name="theme-color" content="#3d5a40" />

  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:locale" content="uk_UA" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description or excerpt }}" />
  <meta property="og:url" content="https://sashkopsy.com{{ page.url }}" />
  <meta property="og:image" content="https://sashkopsy.com/assets/photo.JPG" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ description or excerpt }}" />
  <meta name="twitter:image" content="https://sashkopsy.com/assets/photo.JPG" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />

  {% if ogType == "article" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ description or excerpt }}",
    "image": "https://sashkopsy.com/assets/photo.JPG",
    "datePublished": "{{ date | dateISO }}",
    "dateModified": "{{ date | dateISO }}",
    "inLanguage": "uk",
    "author": {
      "@type": "Person",
      "name": "Олександр Каплун",
      "url": "https://sashkopsy.com/uk/"
    },
    "publisher": {
      "@type": "Person",
      "name": "Олександр Каплун",
      "url": "https://sashkopsy.com/uk/"
    },
    "mainEntityOfPage": "https://sashkopsy.com{{ page.url }}"
  }
  </script>
  {% endif %}
</head>
<body>

  <header class="nav">
    <div class="container nav__inner">
      <a href="/uk/#top" class="brand">
        <svg class="brand__mark" viewBox="0 0 100 100" aria-hidden="true" focusable="false"><path d="M 81 28 A 38 38 0 1 1 60 13" fill="none" stroke="currentColor" stroke-width="7" stroke-linecap="round"/></svg>
        <span>Олександр Каплун</span>
      </a>
      <nav class="nav__links" id="navLinks">
        <a href="/uk/#about">Про мене</a>
        <a href="/uk/#services">Послуги</a>
        <a href="/uk/#approach">Підхід</a>
        <a href="/blog.html">Блог</a>
        <a href="/uk/#contacts" class="nav__cta">Записатися</a>
        <span class="lang-switch">
          <a class="lang-switch__cur" href="/uk/">UK</a>
          <a href="/">EN</a>
          <a href="/ru/">RU</a>
        </span>
      </nav>
      <button class="nav__toggle" id="navToggle" aria-label="Меню">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  {{ content | safe }}

  <footer class="footer">
    <div class="container footer__inner">
      <div>
        <div class="footer__name">Олександр Каплун</div>
        <small>Психолог-консультант · Killarney, Ірландія</small>
      </div>
      <div class="footer__links">
        <a href="/blog.html">Блог</a>
        <a href="/uk/#contacts">Записатися</a>
      </div>
    </div>
    <div class="container" style="margin-top:24px;color:#b9c4ad;font-size:.82rem">
      © <span id="year"></span> Олександр Каплун. Усі права захищені.
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
